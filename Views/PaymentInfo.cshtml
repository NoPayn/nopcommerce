@model Nop.Plugin.Payments.NoPayn.Models.PaymentInfoModel

<div class="payment-info">
    <p><strong>@T("Plugins.Payments.NoPayn.Instructions")</strong></p>
    @for (var i = 0; i < Model.AvailableMethods.Count; i++)
    {
        var method = Model.AvailableMethods[i];
        <div class="form-check" style="margin: 8px 0; padding: 6px 0;">
            <input class="form-check-input" type="radio" name="NoPaynMethod"
                   id="nopayn-@method.Identifier" value="@method.Identifier"
                   @(i == 0 ? "checked" : "") />
            <label class="form-check-label" for="nopayn-@method.Identifier"
                   style="font-weight: 500; cursor: pointer;">
                @method.DisplayName
            </label>
        </div>
    }
</div>
